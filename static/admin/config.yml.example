locale: "ru"
backend:
  name: github
  repo: klavdiy/blog-post
  branch: main
  base_url: https://YOUR-OAUTH-WORKER.workers.dev
  auth_endpoint: /auth

media_folder: "static/images"
public_folder: "/images"

site_url: "https://klavdiy.github.io"
display_url: "https://klavdiy.github.io"
logo_url: "/images/profile.svg"

collections:
  - name: "post"
    label: "Записи"
    label_singular: "Запись"
    folder: "content/post"
    create: true
    delete: false
    slug: "{{year}}-{{month}}-{{day}}-{{slug}}"
    summary: "{{title}} — {{date}}"
    sortable_fields: ["date", "title"]
    fields:
      - label: "Заголовок"
        name: "title"
        widget: "string"
      - label: "Описание (description)"
        name: "description"
        widget: "text"
        required: false
      - label: "Дата"
        name: "date"
        widget: "datetime"
        format: "YYYY-MM-DDTHH:mm:ssZ"
      - label: "Черновик"
        name: "draft"
        widget: "boolean"
        default: true
      - label: "Автор"
        name: "author"
        widget: "string"
        default: "Klavdiy"
      - label: "Теги"
        name: "tags"
        widget: "list"
        required: false
      - label: "Категории"
        name: "categories"
        widget: "list"
        required: false
      - label: "Текст"
        name: "body"
        widget: "markdown"
